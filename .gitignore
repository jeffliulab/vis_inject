# ============================================================
# VisInject 项目 .gitignore
# ============================================================

# 特别的ignore
data
test
hpc_train_with_hf_env.sh

# ---- Python 字节码 ----
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---- 统一模型缓存目录（HuggingFace 权重，体积大）----
model_cache/

# ---- 训练数据（图像数据集，体积大）----
# 通过 prepare_data.py 生成，不纳入版本控制
**/data/train/
**/data/test/
**/data/oracle/
**/data/*.zip
**/data/*.tar
**/data/*.tar.gz

# ---- 模型权重和中间张量（可能很大）----
**/*.pt
**/*.pth
**/*.ckpt
**/*.safetensors
**/*.bin
**/*.npy
**/checkpoints/
**/temp/

# ---- 训练运行日志（由训练脚本自动生成，可本地保留但不入库）----
# 如果你想保留某次重要实验的结果，可以 git add -f 强制追踪
**/logs_and_outputs/stage1*/
**/logs_and_outputs/stage2*/
**/logs_and_outputs/eval_*/
logs_and_outputs
logs_and_outputs_archive

# ---- 演示图像和样本（体积大，本地保留即可）----
demo_images
sample
sample_archive
demo_screenshots
demo_screenshots_archive

# ---- HuggingFace / PyTorch 缓存（位于用户目录，不在项目内）----
.cache/
*.cache

# ---- IDE 配置 ----
.vscode/
.idea/
*.suo
*.user
.cursor/

# ---- 操作系统生成文件 ----
Thumbs.db
Thumbs.db:encdata
desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# ---- Python 打包产物 ----
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ---- 虚拟环境 ----
venv/
env/
.env
.venv/
ENV/

# ---- Jupyter Notebook ----
.ipynb_checkpoints/
*.ipynb

# ---- 临时文件 ----
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ---- 大型二进制演示文件（可单独管理）----
*.pptx
*.ppt
*.key
*.pdf

# ---- 其他 ----
过期文件存档备用/
